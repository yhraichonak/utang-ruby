#10.10.170.121

def MACCL03(device_name, ios_version) #10.10.170.121 - old
  ios_version = "iOS #{ios_version}"
  case ios_version
    
  when "iOS 12.2"       
      
  when "iOS 12.4"       
      if device_name == "iPhone 7 Plus"
          udid = "2120F410-8E66-4ECF-91E0-99398264A753"
      elsif device_name == "iPhone 8"
          udid = "189A42F7-A865-4136-9518-60BCB04890D5"
      elsif device_name == "iPhone X"
          udid = "8187DCFC-8D73-44F0-8CB2-7DC42AF49812"
      elsif device_name == "iPad Pro (12.9-inch)"
          udid = "427A25EC-A92D-41D3-AAFD-33F0B3D27844"
      end
  when "iOS 13.3"       
      if device_name == "iPhone 7 Plus"
          udid = "28855455-7258-43F6-B03D-589EA3B91D51"
      elsif device_name == "iPhone 8"
          udid = "46758995-FC0E-4375-8212-E69A6D318481"
      elsif device_name == "iPhone X"
          udid = "4A1D76EB-FB1E-4CE5-8E23-A4C70A37041D"
      elsif device_name == "iPad Pro (12.9-inch)"
          udid = "AB17B973-0646-4022-994B-364989DBB1BD"
      elsif device_name == "iPhone 11 Pro"
        udid = "76F46ECA-7B77-440A-BC31-54AB511943A6" 
      end 
  end
end

